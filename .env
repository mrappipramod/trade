# ── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Comma-separated list of group/chat IDs to broadcast to
# Negative IDs = groups/supergroups, positive IDs = personal chats/channels
# Add the bot to each group first, then add the group ID here
TELEGRAM_CHAT_IDS=-5277461725,-1001234567890,-1009876543210

# Legacy single ID (still supported — will be merged with TELEGRAM_CHAT_IDS)
# TELEGRAM_CHAT_ID=-5277461725

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENT=you@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Screener settings ─────────────────────────────────────────────────────────
STOCK_UNIVERSE=all
DATA_PERIOD=1y
